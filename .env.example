# Copy this file to .env and fill in your values before running docker compose.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Password for the database (use a strong one in production)
POSTGRES_PASSWORD=changeme123

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate a secure one:
#   openssl rand -base64 32
JWT_SECRET=replace-this-with-a-real-secret-minimum-32-characters

# ─── App public URL (used in emails, CORS, etc.) ─────────────────────────────
# Set to your Cloudflare tunnel domain once configured, e.g. https://app.yourdomain.com
APP_URL=http://localhost:3000

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# 1. Sign up free at https://cloudflare.com
# 2. Go to Zero Trust → Networks → Tunnels → Create a tunnel
# 3. Name it (e.g. "mybiz"), copy the token shown
# 4. Under "Public Hostname", add your domain → Service: http://nginx:80
# 5. Paste the token below
CLOUDFLARE_TUNNEL_TOKEN=paste-your-tunnel-token-here

# ─── AI ───────────────────────────────────────────────────────────────────────
# Anthropic Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=paste-your-anthropic-api-key-here
# (Legacy) Google Gemini / OpenAI keys — no longer used by 1Biz Assistant
# GEMINI_API_KEY=
# OPENAI_API_KEY=
